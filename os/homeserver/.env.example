# Homeserver Configuration
# Secrets live in OpenBao (web UI at vault.<domain>, single userpass login),
# stored as the 'dotenv' field of secret/homeserver. This file is only the
# reference template for the variables that vault entry must contain.
# First-time setup: write this template as .env with real values, then run
#   ./vault-init.sh <ui-password>     (inits vault, seeds it from .env)
# Deploy:  ./deploy.sh                (unseals vault, renders .env, compose up)

# Domain Configuration
# Default: localhost (services accessible as service.localhost)
# Examples: local, home.lan, mynas.local, etc.
DOMAIN=localhost

# User and Group IDs (run 'id' command to get your values)
PUID=1000
PGID=1000

# Timezone
TZ=Europe/Madrid

# Storage Paths
DATA_ROOT=./data/shared
UPLOAD_LOCATION=./data/immich

# Database Configuration (Immich)
DB_PASSWORD=          # generate: openssl rand -base64 24
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# Immich Version
# Pin to a concrete version; bump manually after reading release notes
IMMICH_VERSION=v3.0.1

# Pi-hole Configuration
PIHOLE_PASSWORD=      # generate: openssl rand -base64 24
PIHOLE_DNS=1.1.1.1;1.0.0.1
PIHOLE_API_KEY=

# Tailscale Configuration
TS_AUTHKEY=
