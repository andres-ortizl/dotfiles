# Homeserver Configuration
# Copy this file to .env and adjust the values for your setup

# Domain Configuration
# Default: localhost (services accessible as service.localhost)
# Examples: local, home.lan, mynas.local, etc.
DOMAIN=localhost

# User and Group IDs (run 'id' command to get your values)
PUID=1000
PGID=1000

# Timezone
TZ=Europe/Madrid

# Storage Paths
DATA_ROOT=./data/shared
UPLOAD_LOCATION=./data/immich

# Database Configuration (Immich)
DB_PASSWORD=postgres
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# Immich Version
# Pin to a concrete version; bump manually after reading release notes
IMMICH_VERSION=v3.0.1

# Pi-hole Configuration
PIHOLE_PASSWORD=admin
PIHOLE_DNS=1.1.1.1;1.0.0.1
PIHOLE_API_KEY=

# Tailscale Configuration
TS_AUTHKEY=

# Hermes Agent
HERMES_DASHBOARD_USER=andrew
HERMES_DASHBOARD_PASSWORD=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
