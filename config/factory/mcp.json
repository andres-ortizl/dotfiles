{
  "mcpServers": {
    "context7": {
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "command": "npx",
      "env": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      },
      "type": "stdio"
    },
    "memos": {
      "args": [
        "-y",
        "mcp-server-memos"
      ],
      "command": "npx",
      "env": {
        "MEMOS_TOKEN": "${MEMOS_ACCESS_TOKEN}",
        "MEMOS_URL": "${MEMOS_URL}"
      },
      "type": "stdio"
    }
  }
}
